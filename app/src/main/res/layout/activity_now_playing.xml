<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="@color/absolute">

    <com.google.android.material.card.MaterialCardView
         android:layout_height="0dp"
         android:layout_width="0dp"
         app:layout_constraintDimensionRatio="1:1"
         app:cardElevation="8dp"
         app:cardUseCompatPadding="true"
         app:cardBackgroundColor="#1E1E1E"
         android:layout_marginTop="32dp"
         app:layout_constraintBottom_toTopOf="@id/upperInfo"
         app:cardPreventCornerOverlap="true"
         app:layout_constraintTop_toTopOf="parent"
         android:layout_marginHorizontal="24dp"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         app:cardCornerRadius="24dp"
         android:id="@+id/albumArtCard">

        <ImageView
             android:layout_height="match_parent"
             android:layout_width="match_parent"
             android:scaleType="centerCrop"
             android:src="@drawable/ic_play"
             android:background="#2A2A2A"
             android:id="@+id/albumArt" />

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:orientation="vertical"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         android:layout_marginTop="16dp"
         android:paddingHorizontal="32dp"
         app:layout_constraintTop_toBottomOf="@id/albumArtCard"
         android:id="@+id/upperInfo">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:ellipsize="end"
             android:textSize="18sp"
             android:textColor="#FFFFFF"
             android:maxLines="1"
             android:id="@+id/upperTitle"
             android:text="WILLIAM BLACK &amp; FAIRLANE"
             android:textStyle="bold" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:ellipsize="end"
             android:textSize="14sp"
             android:textColor="#B0B0B0"
             android:layout_marginTop="4dp"
             android:maxLines="2"
             android:id="@+id/upperArtist"
             android:text="BUTTERFLIES (FEAT. DIA FRAMPTON)"
             android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:orientation="vertical"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         android:layout_marginTop="24dp"
         android:paddingHorizontal="32dp"
         app:layout_constraintTop_toBottomOf="@id/upperInfo"
         android:id="@+id/songInfo">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:ellipsize="end"
             android:textSize="16sp"
             android:textColor="#FFFFFF"
             android:maxLines="1"
             android:id="@+id/songTitle"
             android:text="Butterflies (feat. Dia Frampton)" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:ellipsize="end"
             android:textSize="14sp"
             android:textColor="#B0B0B0"
             android:layout_marginTop="2dp"
             android:maxLines="1"
             android:id="@+id/songArtist"
             android:text="William Black, Fairlane" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:ellipsize="end"
             android:textSize="13sp"
             android:textColor="#888888"
             android:layout_marginTop="2dp"
             android:maxLines="1"
             android:id="@+id/songAlbum"
             android:text="Butterflies (feat. Dia Frampton)" />

    </LinearLayout>

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:orientation="horizontal"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         android:layout_marginTop="32dp"
         app:layout_constraintTop_toBottomOf="@id/songInfo"
         android:paddingHorizontal="32dp"
         android:id="@+id/progressContainer">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:layout_marginEnd="8dp"
             android:textSize="12sp"
             android:fontFamily="sans-serif-medium"
             android:textColor="#FFFFFF"
             android:id="@+id/currentTime"
             android:text="0:00"
             android:layout_gravity="start|center_vertical" />

        <com.zanghai.music.ui.custom.NoThumbSeekBar
             android:layout_height="wrap_content"
             android:layout_width="0dp"
             android:max="1000"
             android:background="@android:color/transparent"
             android:paddingVertical="8dp"
             android:splitTrack="false"
             android:progressDrawable="@drawable/seekbar_ios"
             android:layout_weight="1"
             android:id="@+id/seekBar"
             android:layout_gravity="center" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:textSize="12sp"
             android:fontFamily="sans-serif-medium"
             android:textColor="#FFFFFF"
             android:layout_marginStart="8dp"
             android:id="@+id/totalTime"
             android:text="3:21"
             android:layout_gravity="end|center_vertical" />

    </LinearLayout>

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="wrap_content"
         android:gravity="center"
         android:orientation="horizontal"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         android:layout_marginTop="24dp"
         app:layout_constraintTop_toBottomOf="@id/progressContainer"
         android:id="@+id/controls_main">

        <ImageView
             android:layout_height="48dp"
             android:layout_width="48dp"
             android:src="@drawable/ic_previous"
             android:background="?selectableItemBackgroundBorderless"
             android:padding="12dp"
             android:tint="#FFFFFF"
             android:id="@+id/btnPrev" />

        <ImageView
             android:layout_height="64dp"
             android:layout_width="64dp"
             android:src="@drawable/ic_play"
             android:background="?selectableItemBackgroundBorderless"
             android:layout_marginHorizontal="24dp"
             android:padding="16dp"
             android:tint="#FFFFFF"
             android:id="@+id/btnPlayPause" />

        <ImageView
             android:layout_height="48dp"
             android:layout_width="48dp"
             android:src="@drawable/ic_next"
             android:background="?selectableItemBackgroundBorderless"
             android:padding="12dp"
             android:tint="#FFFFFF"
             android:id="@+id/btnNext" />

    </LinearLayout>

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="wrap_content"
         android:gravity="center"
         android:orientation="horizontal"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         android:layout_marginTop="12dp"
         app:layout_constraintTop_toBottomOf="@id/controls_main"
         android:id="@+id/controls_secondary">

        <com.google.android.material.card.MaterialCardView
             android:layout_height="38dp"
             android:layout_width="48dp"
             android:layout_marginEnd="0.6dp"
             android:background="@drawable/ripple_lyrics"
             android:clickable="true"
             app:shapeAppearanceOverlay="@style/ShapeLyricsCard"
             app:cardElevation="0dp"
             app:cardBackgroundColor="#33FFFFFF"
             android:id="@+id/btnLyrics"
             android:focusable="true">

            <ImageView
                 android:layout_height="match_parent"
                 android:layout_width="match_parent"
                 android:scaleType="centerInside"
                 android:src="@drawable/lyrics"
                 android:clickable="false"
                 android:padding="6dp"
                 android:tint="#FFFFFF"
                 android:focusable="false" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="38dp"
             android:layout_width="48dp"
             android:background="@drawable/ripple_playback"
             android:clickable="true"
             android:id="@+id/btnPlaybackMode"
             app:shapeAppearanceOverlay="@style/ShapePlaybackCard"
             app:cardElevation="0dp"
             android:layout_marginStart="0.6dp"
             app:cardBackgroundColor="#33FFFFFF"
             android:focusable="true">

            <ImageView
                 android:layout_height="match_parent"
                 android:layout_width="match_parent"
                 android:scaleType="centerInside"
                 android:src="@drawable/shuffle"
                 android:clickable="false"
                 android:padding="6dp"
                 android:tint="#FFFFFF"
                 android:focusable="false" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_marginBottom="16dp"
         android:gravity="center_vertical"
         android:orientation="horizontal"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         android:layout_marginTop="40dp"
         app:layout_constraintBottom_toBottomOf="parent"
         android:paddingHorizontal="32dp"
         app:layout_constraintTop_toBottomOf="@id/controls_main"
         android:id="@+id/volumeContainer">

        <ImageView
             android:layout_height="20dp"
             android:layout_width="20dp"
             android:src="@drawable/low_vol"
             android:tint="#FFFFFF"
             android:id="@+id/btnVolumeLow" />

        <androidx.appcompat.widget.AppCompatSeekBar
             android:layout_height="wrap_content"
             android:layout_width="0dp"
             android:max="100"
             android:thumb="@null"
             android:background="@android:color/transparent"
             android:layout_marginHorizontal="12dp"
             android:splitTrack="false"
             android:progress="70"
             android:layout_weight="1"
             android:progressDrawable="@drawable/seekbar_ios"
             android:id="@+id/volumeSeekBar" />

        <ImageView
             android:layout_height="20dp"
             android:layout_width="20dp"
             android:src="@drawable/high_vol"
             android:tint="#FFFFFF"
             android:id="@+id/btnVolumeHigh" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>